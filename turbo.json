{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", "build/client/**"],
      "env": ["VITE_BUILD_NUMBER", "VITE_VERSION"]
    },
    "lint": {},
    "test": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs": {
      "inputs": ["$TURBO_DEFAULT$", "antora-playbook.yml"],
      "outputs": ["build/**"]
    },
    "clean": {
      "cache": false,
      "dependsOn": []
    },
    "typecheck": {
      "outputs": ["dist/**"],
      "dependsOn": ["^typecheck"]
    },
    "@repo/frontend#typecheck": {
      "outputs": [".react-router/**"],
      "dependsOn": ["^typecheck"]
    },
    "@repo/frontend#build": {
      "inputs": ["public/**", "react-router.config.ts", "vite.config.ts", "styles/tailwind.css"],
      "dependsOn": ["^build"],
      "outputs": ["build/client/**"],
      "env": [
        "VITE_BUILD_NUMBER",
        "VITE_VERSION",
        "VITE_CESIUM_ION_TOKEN",
        "VITE_GEOAPIFY_KEY",
        "VITE_UMAMI_WEBSITE_ID",
        "VITE_UMAMI_SRC"
      ]
    },
    "@repo/ui#typecheck": {
      "outputs": [],
      "dependsOn": ["^typecheck"]
    }
  }
}
