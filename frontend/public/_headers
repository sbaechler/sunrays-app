# Security-Header für Cloudflare Pages (https://developers.cloudflare.com/pages/configuration/headers/)
# CSP: erlaubt genau die im MVP genutzten Dienste — OpenFreeMap (Tiles),
# Cesium ion + Bing (3D), Geoapify/Photon (Suche), Umami/Cloudflare (Telemetrie).

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(), microphone=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cloud.umami.is https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://tiles.openfreemap.org https://*.virtualearth.net https://assets.ion.cesium.com https://api.cesium.com; connect-src 'self' data: blob: https://tiles.openfreemap.org https://api.cesium.com https://assets.ion.cesium.com https://assets.cesium.com https://*.virtualearth.net https://dev.virtualearth.net https://api.geoapify.com https://photon.komoot.io https://cloud.umami.is https://cloudflareinsights.com; worker-src 'self' blob:; font-src 'self' data:; frame-ancestors 'none'

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/cesium/*
  Cache-Control: public, max-age=86400

/sw.js
  Cache-Control: no-cache
